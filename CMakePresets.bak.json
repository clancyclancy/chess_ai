{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs2026-debug",
      "displayName": "VS2026 Debug (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/vs2026-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "environment": {
        "VCPKG_ROOT": "C:/vcpkg"
      }
    },
    {
      "name": "vs2026-release",
      "displayName": "VS2026 Release (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/vs2026-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /Zi",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "/DEBUG"
      },
      "environment": {
        "VCPKG_ROOT": "C:/vcpkg"
      }
    }

  ]
}
